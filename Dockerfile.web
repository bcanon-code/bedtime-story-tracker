FROM node:22-alpine AS build

WORKDIR /app

ARG EXPO_PUBLIC_API_BASE_URL
ARG APP_VERSION
ARG BUILD_NUMBER
ARG GIT_SHA
ARG GIT_DIRTY=false
ARG BUILD_DATE
ARG BUILD_ENVIRONMENT=Server
ARG OCI_SOURCE

ENV EXPO_PUBLIC_API_BASE_URL=${EXPO_PUBLIC_API_BASE_URL}
ENV EXPO_PUBLIC_APP_VERSION=${APP_VERSION} \
    EXPO_PUBLIC_BUILD_NUMBER=${BUILD_NUMBER} \
    EXPO_PUBLIC_GIT_SHA=${GIT_SHA} \
    EXPO_PUBLIC_GIT_DIRTY=${GIT_DIRTY} \
    EXPO_PUBLIC_BUILD_TIME_UTC=${BUILD_DATE} \
    EXPO_PUBLIC_BUILD_ENVIRONMENT=${BUILD_ENVIRONMENT}

COPY package.json package-lock.json ./
RUN npm ci

COPY app.config.js version.json index.ts App.tsx tsconfig.json ./
COPY src ./src

RUN npx expo export --platform web

FROM nginxinc/nginx-unprivileged:1.29-alpine AS runtime

ARG GIT_SHA=unknown
ARG BUILD_DATE=unknown
ARG APP_VERSION=unknown
ARG OCI_SOURCE=unknown

LABEL org.opencontainers.image.title="Bedtime Story Tracker Web" \
      org.opencontainers.image.version="${APP_VERSION}" \
      org.opencontainers.image.revision="${GIT_SHA}" \
      org.opencontainers.image.created="${BUILD_DATE}" \
      org.opencontainers.image.source="${OCI_SOURCE}"

COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD wget -q -O /dev/null http://127.0.0.1:8080/ || exit 1
