# Copy this file to .env.server and replace every placeholder.
# Host-only: keep 127.0.0.1 and use SERVER_HOST=localhost.
# LAN access: set SERVER_BIND_ADDRESS to this machine's trusted LAN IP and
# SERVER_HOST to the hostname or IP that client browsers use.
SERVER_HOST=replace-with-server-host
SERVER_BIND_ADDRESS=127.0.0.1
PORT_BLOCK_START=12000
FRONTEND_PORT=12000
API_PORT=12001
FRONTEND_ORIGIN=http://replace-with-server-host:12000
EXPO_PUBLIC_API_BASE_URL=http://replace-with-server-host:12001
ConnectionStrings__ApplicationDatabase=Server=replace-with-sql-host;Database=BedtimeStoryTracker_Prod;User ID=replace-with-sql-user;Password=replace-with-sql-password;Encrypt=True;TrustServerCertificate=True
# Used only by Reset-Database.ps1; requires permission to manage logins and databases.
ResetDatabase__AdminConnectionString=Server=replace-with-sql-host;Database=master;User ID=replace-with-admin-user;Password=replace-with-admin-password;Encrypt=True;TrustServerCertificate=True
